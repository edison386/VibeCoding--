.container {
  min-height: 100vh;
  background: #F7F5F2;
  padding: 20rpx;
}

.hero {
  background: #4CAF7D;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.name {
  font-size: 22px;
  font-weight: 700;
}

.slogan {
  margin-top: 10rpx;
  font-size: 14px;
  opacity: 0.95;
}

.version {
  margin-top: 12rpx;
  font-size: 12px;
  opacity: 0.9;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 16px;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.text {
  font-size: 14px;
  line-height: 1.7;
  color: #666;
}
