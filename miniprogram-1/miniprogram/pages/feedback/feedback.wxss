.container {
  min-height: 100vh;
  background: #F7F5F2;
  padding: 20rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.label {
  font-size: 14px;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.textarea {
  width: 100%;
  min-height: 260rpx;
  background: #F7F5F2;
  border-radius: 8rpx;
  padding: 14rpx;
  font-size: 14px;
}

.input {
  width: 100%;
  height: 72rpx;
  background: #F7F5F2;
  border-radius: 8rpx;
  padding: 0 14rpx;
  font-size: 14px;
}

.submit-btn {
  margin-top: 20rpx;
  background: #4CAF7D !important;
  color: #FFFFFF !important;
  border-radius: 40rpx;
  font-size: 16px;
}
