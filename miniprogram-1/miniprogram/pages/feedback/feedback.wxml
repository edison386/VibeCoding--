<view class="container">
  <view class="card">
    <view class="label">反馈内容</view>
    <textarea class="textarea" maxlength="500" placeholder="请描述你遇到的问题或建议（最多 500 字）" value="{{content}}" bindinput="onContentInput"></textarea>
  </view>

  <view class="card">
    <view class="label">联系方式（选填）</view>
    <input class="input" placeholder="微信号 / 邮箱 / 手机号" value="{{contact}}" bindinput="onContactInput" />
  </view>

  <button class="submit-btn" bindtap="submitFeedback">提交反馈</button>
</view>
