.container {
  background-color: #F7F5F2;
  min-height: 100vh;
  padding: 16rpx;
}

.calendar-section {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.calendar-header {
  text-align: center;
  margin-bottom: 16rpx;
}

.month-year {
  font-size: 16px;
  font-weight: 500;
  color: #2D2D2D;
}

.calendar-weekdays {
  display: flex;
  justify-content: space-around;
  margin-bottom: 12rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 12px;
  color: #8C8C8C;
  padding: 8rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-day {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 14px;
  color: #2D2D2D;
}

.day-number {
  font-size: 16px;
  font-weight: 500;
  color: inherit;
}

.future-date {
  color: #CCCCCC;
}

.calendar-day.selected {
  background-color: #4CAF7D;
  color: #FFFFFF;
}

.calendar-day:not(.selected):active {
  background-color: #F7F5F2;
}

.record-indicator {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  background-color: #4CAF7D;
  border-radius: 50%;
}

.record-count {
  position: absolute;
  bottom: -12rpx;
  right: -4rpx;
  width: 20rpx;
  height: 20rpx;
  background-color: #FF8A50;
  color: #FFFFFF;
  font-size: 10px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.records-section {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 16px;
  font-weight: 500;
  color: #2D2D2D;
}

.records-scroll {
  max-height: 56vh;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 14px;
  color: #8C8C8C;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 12rpx;
  border-radius: 8rpx;
  background: #F7F5F2;
}

.group-header-active {
  background: rgba(76, 175, 125, 0.12);
}

.group-date {
  font-size: 14px;
  font-weight: 600;
  color: #2D2D2D;
}

.group-count {
  font-size: 12px;
  color: #8C8C8C;
}

.record-card {
  background-color: #F7F5F2;
  border-radius: 12rpx;
  padding: 20rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #E8E8E8;
}

.record-time {
  font-size: 18px;
  font-weight: 600;
  color: #2D2D2D;
}

.record-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 12px;
}

.action-btn.edit {
  background-color: #4CAF7D;
  color: #FFFFFF;
}

.action-btn.delete {
  background-color: #F44336;
  color: #FFFFFF;
}

.record-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  display: flex;
  align-items: center;
  min-height: 44rpx;
}

.item-label {
  width: 140rpx;
  font-size: 14px;
  color: #8C8C8C;
  flex-shrink: 0;
}

.item-value {
  font-size: 14px;
  color: #2D2D2D;
  font-weight: 500;
}

.color-indicator {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 1rpx solid transparent;
}

.color-label {
  font-size: 14px;
  color: #2D2D2D;
}

.feelings-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.feeling-tag {
  padding: 6rpx 16rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 12px;
  color: #4CAF7D;
  border: 1rpx solid #4CAF7D;
}

.item-value.note {
  flex: 1;
  color: #666;
  font-weight: normal;
}
