.container {
  background-color: #F7F5F2;
  min-height: 100vh;
  padding: 16rpx;
}

.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  border-radius: 8rpx;
  font-size: 14px;
  color: #8C8C8C;
}

.tab-item.active {
  background-color: #4CAF7D;
  color: #FFFFFF;
}

.warning-card {
  background: #FFF6EC;
  border-left: 8rpx solid #FF8A50;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.warning-title {
  font-size: 15px;
  font-weight: 600;
  color: #B65A2F;
  margin-bottom: 8rpx;
}

.warning-message {
  font-size: 13px;
  line-height: 1.6;
  color: #7A4A2E;
}

.warning-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.warning-link,
.warning-dismiss {
  font-size: 13px;
  color: #4CAF7D;
}

.warning-dismiss {
  color: #8C8C8C;
}

.card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.loading-card,
.empty-card {
  text-align: center;
  color: #8C8C8C;
  font-size: 14px;
  padding: 36rpx 20rpx;
}

.empty-title {
  color: #2D2D2D;
  font-size: 16px;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 13px;
  color: #8C8C8C;
}

.card-title {
  font-size: 16px;
  font-weight: 500;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.frequency-scroll {
  width: 100%;
}

.frequency-chart {
  display: flex;
  align-items: flex-end;
  min-height: 250rpx;
  padding: 0 8rpx;
}

.frequency-chart.month-mode {
  min-width: 1200rpx;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 56rpx;
}

.bar-container {
  height: 200rpx;
  width: 36rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 8rpx;
}

.bar {
  width: 28rpx;
  background-color: #4CAF7D;
  border-radius: 12rpx 12rpx 0 0;
}

.bar-label {
  font-size: 11px;
  color: #8C8C8C;
  margin-bottom: 4rpx;
}

.bar-value {
  font-size: 11px;
  color: #2D2D2D;
  font-weight: 500;
}

.type-distribution {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.type-item {
  display: flex;
  align-items: center;
  padding: 12rpx;
  background-color: #F7F5F2;
  border-radius: 8rpx;
}

.type-color {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.type-info {
  flex: 1;
}

.type-name {
  font-size: 14px;
  color: #2D2D2D;
}

.type-count {
  font-size: 12px;
  color: #8C8C8C;
}

.regularity-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.regularity-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #EDEDED;
}

.regularity-item:last-child {
  border-bottom: none;
}

.regularity-label {
  font-size: 14px;
  color: #8C8C8C;
}

.regularity-value {
  font-size: 14px;
  color: #2D2D2D;
  font-weight: 500;
}

.health-assessment {
  padding: 16rpx;
  background-color: #F7F5F2;
  border-left: 8rpx solid #4CAF7D;
  border-radius: 0 8rpx 8rpx 0;
}

.assessment-status {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.assessment-message {
  font-size: 14px;
  color: #8C8C8C;
  line-height: 1.5;
}
