<view class="container">
  <view class="tab-bar">
    <view wx:for="{{rangeTabs}}" wx:key="key" class="tab-item {{activeRange === item.key ? 'active' : ''}}" data-tab="{{item.key}}" bindtap="switchTab">{{item.label}}</view>
  </view>

  <view wx:if="{{loading}}" class="card loading-card">统计数据加载中...</view>

  <view wx:elif="{{noData}}" class="card empty-card">
    <view class="empty-title">暂无统计数据</view>
    <view class="empty-desc">先完成一条记录，数据会自动生成。</view>
  </view>

  <block wx:else>
    <view wx:if="{{abnormalWarning.show}}" class="warning-card">
      <view class="warning-title">近期肠道状态需关注</view>
      <view class="warning-message">{{abnormalWarning.message}}</view>
      <view class="warning-actions">
        <view class="warning-link" bindtap="showImprovementTips">了解改善建议</view>
        <view class="warning-dismiss" bindtap="ignoreWarning">忽略</view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">排便频次</view>
      <scroll-view scroll-x class="frequency-scroll">
        <view class="frequency-chart {{activeRange === 'month' ? 'month-mode' : ''}}">
          <view wx:for="{{frequencyData}}" wx:key="label" class="chart-bar">
            <view class="bar-container">
              <view class="bar" style="height: {{item.height}}rpx;"></view>
            </view>
            <view class="bar-label">{{item.label}}</view>
            <view class="bar-value">{{item.count}}次</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="card">
      <view class="card-title">形态分布</view>
      <view class="type-distribution">
        <view wx:for="{{typeDistribution}}" wx:key="type" class="type-item">
          <view class="type-color" style="background-color: {{item.color}}"></view>
          <view class="type-info">
            <view class="type-name">{{item.typeDesc}}</view>
            <view class="type-count">{{item.count}}次</view>
          </view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">规律性分析</view>
      <view class="regularity-info">
        <view class="regularity-item">
          <view class="regularity-label">平均排便时间</view>
          <view class="regularity-value">{{regularity.averageTime}}</view>
        </view>
        <view class="regularity-item">
          <view class="regularity-label">平均间隔</view>
          <view class="regularity-value">{{regularity.averageInterval}}</view>
        </view>
        <view class="regularity-item">
          <view class="regularity-label">本月总计</view>
          <view class="regularity-value">{{regularity.monthTotal}}次</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">健康评估</view>
      <view class="health-assessment" style="border-left-color: {{healthAssessment.color}};">
        <view class="assessment-status" style="color: {{healthAssessment.color}};">{{healthAssessment.label}}</view>
        <view class="assessment-message">{{healthAssessment.message}}</view>
      </view>
    </view>
  </block>
</view>
