.container {
  background-color: #F7F5F2;
  min-height: 100vh;
  padding: 16rpx;
  position: relative;
}

.header {
  margin-bottom: 16rpx;
}

.greeting {
  font-size: 20px;
  font-weight: 500;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.date {
  font-size: 14px;
  color: #8C8C8C;
}

.status-card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  cursor: pointer;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-title {
  font-size: 16px;
  font-weight: 500;
  color: #2D2D2D;
}

.status-arrow {
  font-size: 16px;
  color: #8C8C8C;
}

.recorded-status {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  background-color: #F7F5F2;
  border-radius: 8rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #EDEDED;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 16px;
  font-weight: 500;
  color: #2D2D2D;
  min-width: 80rpx;
}

.record-type {
  font-size: 14px;
  color: #4CAF7D;
  font-weight: 500;
}

.record-count {
  font-size: 14px;
  color: #8C8C8C;
  margin-top: 8rpx;
  text-align: right;
}

.unrecorded-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background-color: #F7F5F2;
  border-radius: 8rpx;
}

.unrecorded-icon {
  font-size: 48px;
  margin-bottom: 16rpx;
}

.unrecorded-text {
  font-size: 16px;
  color: #8C8C8C;
}

.consecutive-banner {
  background-color: #FF8A50;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.fire-icon {
  font-size: 24px;
}

.consecutive-text {
  font-size: 16px;
  font-weight: 500;
}

.week-summary-card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 240rpx; /* 为悬浮按钮留出空间 */
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 16px;
  font-weight: 500;
  color: #2D2D2D;
  margin-bottom: 16rpx;
}

.week-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 160rpx;
}

.chart-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.chart-bar-container {
  height: 120rpx;
  width: 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 8rpx;
}

.chart-bar {
  width: 24rpx;
  background-color: #4CAF7D;
  border-radius: 12rpx 12rpx 0 0;
  transition: height 0.3s ease;
}

.chart-label {
  font-size: 12px;
  color: #8C8C8C;
  margin-bottom: 4rpx;
}

.chart-value {
  font-size: 12px;
  color: #2D2D2D;
  font-weight: 500;
}

.fab {
  position: fixed;
  bottom: 120rpx;
  right: 36rpx;
  width: 112rpx;
  height: 112rpx;
  background-color: #FF8A50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 138, 80, 0.35);
  cursor: pointer;
  z-index: 999;
}

.fab-recorded {
  background-color: #4CAF7D;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 125, 0.35);
}

.fab-plus {
  font-size: 56rpx;
  color: #FFFFFF;
  line-height: 1;
  margin-top: -6rpx;
}
