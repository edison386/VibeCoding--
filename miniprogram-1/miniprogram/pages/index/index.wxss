.container {
  min-height: 100vh;
  padding: 24rpx 20rpx 0;
  position: relative;
}

.header {
  margin-bottom: 20rpx;
  padding: 8rpx 4rpx 0;
}

.greeting {
  font-size: 42rpx;
  font-weight: 700;
  color: #1F2A22;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.date {
  font-size: 24rpx;
  color: #6A7C70;
}

.status-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(220, 231, 222, 0.85);
  box-shadow: 0 12rpx 34rpx rgba(31, 42, 34, 0.06);
  cursor: pointer;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.status-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2A22;
}

.status-arrow {
  min-width: 76rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background-color: #F0F7F2;
  color: #3AA36E;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recorded-status {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  background: linear-gradient(135deg, #F4FBF6, #F6FAF8);
  border-radius: 18rpx;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 74rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #E2ECE4;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2A22;
  min-width: 120rpx;
}

.record-type {
  font-size: 26rpx;
  color: #357A56;
  font-weight: 500;
  line-height: 1.45;
}

.record-count {
  font-size: 24rpx;
  color: #728377;
  margin-top: 8rpx;
  text-align: right;
}

.unrecorded-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 34rpx 24rpx;
  background: linear-gradient(135deg, #F6FBF8, #F0F7F2);
  border-radius: 18rpx;
  border: 1rpx dashed rgba(58, 163, 110, 0.35);
}

.unrecorded-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #D8F0E0, #EEF8F1);
  color: #3AA36E;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.unrecorded-text {
  font-size: 26rpx;
  color: #667A6D;
  line-height: 1.5;
  text-align: center;
}

.consecutive-banner {
  background: linear-gradient(135deg, #F7AE75, #F09A5A);
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(240, 154, 90, 0.3);
}

.fire-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.24);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.consecutive-text {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.week-summary-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 26rpx;
  margin-bottom: 240rpx; /* 为悬浮按钮留出空间 */
  border: 1rpx solid rgba(220, 231, 222, 0.8);
  box-shadow: 0 12rpx 34rpx rgba(31, 42, 34, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2A22;
  margin-bottom: 18rpx;
}

.week-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 180rpx;
}

.chart-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.chart-bar-container {
  height: 132rpx;
  width: 40rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 10rpx;
}

.chart-bar {
  width: 30rpx;
  background: linear-gradient(180deg, #5BC489, #3AA36E);
  border-radius: 15rpx 15rpx 0 0;
  transition: height 0.3s ease;
}

.chart-label {
  font-size: 21rpx;
  color: #7B8D82;
  margin-bottom: 4rpx;
}

.chart-value {
  font-size: 21rpx;
  color: #1F2A22;
  font-weight: 600;
}

.fab {
  position: fixed;
  bottom: 132rpx;
  right: 32rpx;
  width: 116rpx;
  height: 116rpx;
  background: linear-gradient(135deg, #F4AD77, #EF9758);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 30rpx rgba(240, 154, 90, 0.34);
  cursor: pointer;
  z-index: 999;
  animation: fab-breath 2.4s ease-in-out infinite;
}

.fab-recorded {
  background: linear-gradient(135deg, #4FB77D, #318D5E);
  box-shadow: 0 14rpx 30rpx rgba(58, 163, 110, 0.34);
}

.fab-plus {
  font-size: 62rpx;
  color: #FFFFFF;
  line-height: 1;
  margin-top: -8rpx;
  font-weight: 500;
}

@keyframes fab-breath {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4rpx);
  }
  100% {
    transform: translateY(0);
  }
}
