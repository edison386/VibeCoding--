.container {
  min-height: 100vh;
  padding: 24rpx 20rpx 0;
}

.step-indicator {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(220, 231, 222, 0.85);
  box-shadow: 0 12rpx 34rpx rgba(31, 42, 34, 0.06);
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.step-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2A22;
}

.step-progress {
  min-height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #F0F7F2;
  color: #3AA36E;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-track {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.step-number {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: #E7EFE8;
  color: #809286;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.step-item.active .step-number {
  background: linear-gradient(135deg, #4DB57B, #328E60);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(58, 163, 110, 0.25);
}

.step-label {
  font-size: 21rpx;
  color: #788A7F;
  white-space: nowrap;
  text-align: center;
}

.step-item.active .step-label {
  color: #3A9263;
  font-weight: 600;
}

.step-line {
  flex: 2;
  height: 4rpx;
  background-color: #E5EEE6;
  margin: 0 16rpx;
  border-radius: 999rpx;
}

.step-line.active {
  background-color: #3AA36E;
}

.form-content {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(220, 231, 222, 0.85);
  box-shadow: 0 12rpx 34rpx rgba(31, 42, 34, 0.06);
  min-height: 560rpx;
}

.step-form-desc {
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #F1F8F3;
  color: #5F7266;
  font-size: 24rpx;
  line-height: 1.55;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2A22;
  margin-bottom: 12rpx;
}

.form-control {
  width: 100%;
}

.picker {
  min-height: 88rpx;
  padding: 0 20rpx;
  background-color: #F2F7F3;
  border-radius: 16rpx;
  border: 1rpx solid rgba(220, 231, 222, 0.9);
  font-size: 26rpx;
  color: #1F2A22;
  display: flex;
  align-items: center;
}

.bristol-types {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.type-item {
  display: flex;
  align-items: center;
  min-height: 98rpx;
  padding: 16rpx;
  background-color: #F5FAF7;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
}

.type-item.selected {
  border-color: #3AA36E;
  background-color: rgba(58, 163, 110, 0.12);
  box-shadow: 0 8rpx 18rpx rgba(58, 163, 110, 0.16);
}

.type-color {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.type-info {
  flex: 1;
}

.type-name {
  font-size: 25rpx;
  font-weight: 600;
  color: #1F2A22;
  margin-bottom: 4rpx;
}

.type-desc {
  font-size: 22rpx;
  color: #6E8175;
}

.color-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 124rpx;
  padding: 14rpx;
  background-color: #F5FAF7;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
}

.color-item.selected {
  border-color: #3AA36E;
  background-color: rgba(58, 163, 110, 0.12);
  box-shadow: 0 8rpx 18rpx rgba(58, 163, 110, 0.16);
}

.color-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
  border: 2rpx solid #E2ECE4;
}

.color-label {
  font-size: 22rpx;
  color: #64786C;
}

.feeling-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.feeling-item {
  min-height: 64rpx;
  padding: 0 20rpx;
  background-color: #F2F7F3;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #667A6E;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.feeling-item.selected {
  background-color: #3AA36E !important;
  color: #FFFFFF !important;
  border-color: #3AA36E !important;
  box-shadow: 0 8rpx 20rpx rgba(58, 163, 110, 0.28);
}

textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 16rpx;
  background-color: #F2F7F3;
  border-radius: 16rpx;
  border: 1rpx solid rgba(220, 231, 222, 0.9);
  font-size: 24rpx;
  color: #1F2A22;
  resize: none;
  line-height: 1.55;
}

.bottom-buttons {
  display: flex;
  gap: 16rpx;
  padding: 0 0 26rpx;
  padding: 0 0 calc(26rpx + env(safe-area-inset-bottom));
}

button {
  flex: 1;
  min-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prev-button {
  background-color: #FFFFFF;
  color: #3AA36E;
  border: 2rpx solid rgba(58, 163, 110, 0.45);
}

.next-button,
.save-button {
  background: linear-gradient(135deg, #4CB47A, #338F60);
  color: #FFFFFF;
  border: none;
  box-shadow: 0 10rpx 24rpx rgba(58, 163, 110, 0.26);
}

.save-button {
  background: linear-gradient(135deg, #4CB47A, #338F60);
}
